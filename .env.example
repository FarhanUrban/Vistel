# Set to "true" to use mock services locally (no Firebase credentials needed)
# Set to "false" to connect to live Firebase (requires all VITE_FIREBASE_* vars below)
# Production builds always use live Firebase via .env.production
VITE_USE_MOCK_SERVICES=true

# Document file storage: "local" (IndexedDB, free) or "firebase" (requires paid Storage plan)
VITE_DOCUMENT_STORAGE=local

# Firebase web app config — from Firebase Console > Project Settings > Your apps
# Copy this file to .env and fill in real values. Never commit .env.
# Firebase web API keys are public in the client bundle; protect your project with
# Firebase Security Rules, App Check, and API key restrictions in Google Cloud Console.
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
