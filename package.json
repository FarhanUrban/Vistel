{
  "name": "vislet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "firebase:login": "firebase login",
    "firebase:deploy": "npm run build && firebase deploy",
    "firebase:deploy:hosting": "npm run build && firebase deploy --only hosting",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,storage:rules",
    "firebase:deploy:firestore-rules": "firebase deploy --only firestore:rules",
    "firebase:deploy:storage-rules": "firebase deploy --only storage:rules",
    "firebase:deploy:indexes": "firebase deploy --only firestore:indexes",
    "pages:deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@dataconnect/generated": "file:src/dataconnect-generated",
    "@vueuse/core": "^13.0.0",
    "firebase": "^11.10.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "firebase-tools": "^15.23.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.0",
    "vite": "^8.1.4",
    "vue-tsc": "^2.0.0",
    "wrangler": "^4.111.0"
  }
}
