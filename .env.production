# Production builds always use live Firebase (overrides .env mock default)
VITE_USE_MOCK_SERVICES=false

# Document file bytes in Cloudflare R2 (Pages Function + CLIENT_DATA binding).
# Application metadata is stored encrypted in R2 — never in browser localStorage.
VITE_DOCUMENT_STORAGE=r2

# Portal bridge for admin/agency demo accounts (must match Pages PORTAL_BRIDGE_SECRET).
VITE_PORTAL_BRIDGE_SECRET=vislet-portal-bridge-v1
